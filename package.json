{
  "name": "os3d",
  "version": "1.0.0",
  "description": "Osteometric Sorting 3D - PLY model visualization, landmark placement, and mesh comparison",
  "author": "Jeff Lynch <jjlynch@bioarch.net>",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "npx electron-builder"
  },
  "devDependencies": {
    "electron": "34.0.0",
    "electron-builder": "^26"
  },
  "build": {
    "appId": "com.os3d.app",
    "productName": "OS3D",
    "files": [
      "main.js",
      "preload.js",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "sidecar/",
        "to": "sidecar/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png",
      "category": "Science"
    }
  }
}